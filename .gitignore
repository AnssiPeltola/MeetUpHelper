# Dart/Flutter specific
.dart_tool/
.packages
build/
pubspec.lock  # Check-in if you're building an application
doc/api/      # Generated by dartdoc, remove if not needed
.env*         # dotenv environment variables file

# Avoid committing generated Javascript files from Dart
*.dart.js
*.info.json   # Produced by the --dump-info flag.
*.js          # When generated by dart2js (don't include if you have JS source files)
*.js_
*.js.deps
*.js.map

# Flutter specific
.flutter-plugins
.flutter-plugins-dependencies

# IDEs and editors
.vscode/
.idea/
*.iml

# Node.js specific
node_modules/
npm-debug.log

# System files
.DS_Store     # macOS specific
Thumbs.db     # Windows specific
Desktop.ini   # Windows specific

# Others
*.lock
*.log
*.g.dart
*.part
*.tmp
*.swp
*.un~
package-lock.json
flutter_export_environment.sh
*.class
*.o
*.so
*.pyc
*.pyo
*.pyd
*.bak
*.tmp
*~
*.out
